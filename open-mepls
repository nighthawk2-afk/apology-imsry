<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ok wait</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;700;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Nunito', sans-serif;
    background: #f0f0f0;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .card {
    background: white;
    border-radius: 20px;
    padding: 44px 44px 36px;
    max-width: 500px;
    width: 92%;
    box-shadow: 6px 6px 0px #222;
    border: 2.5px solid #222;
    text-align: center;
    position: relative;
    z-index: 10;
  }

  .emoji-big {
    font-size: 68px;
    display: block;
    margin-bottom: 12px;
    animation: wobble 1.6s ease-in-out infinite;
  }
  @keyframes wobble {
    0%,100% { transform: rotate(-4deg); }
    50%      { transform: rotate(4deg); }
  }

  h1 {
    font-family: 'Fredoka One', cursive;
    font-size: 2rem;
    color: #111;
    margin-bottom: 8px;
    line-height: 1.2;
  }

  .subtext {
    color: #666;
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 30px;
  }

  .btn-row {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    font-family: 'Fredoka One', cursive;
    font-size: 1.15rem;
    padding: 13px 32px;
    border: 2.5px solid #222;
    border-radius: 12px;
    cursor: pointer;
    box-shadow: 3px 3px 0 #222;
    transition: transform 0.1s, box-shadow 0.1s;
    outline: none;
    letter-spacing: 0.5px;
  }
  .btn:hover  { transform: translate(-2px,-2px); box-shadow: 5px 5px 0 #222; }
  .btn:active { transform: translate(2px,2px);   box-shadow: 1px 1px 0 #222; }

  .btn-yes     { background: #ff5c5c; color: white; }
  .btn-no      { background: #ffd93d; color: #222;  }
  .btn-ok      { background: #4ecb71; color: white; font-size: 1.2rem; }
  .btn-forgive { background: #4d96ff; color: white; }

  .error-box {
    display: none;
    background: #fff3cd;
    border: 2px solid #f0a500;
    border-radius: 10px;
    padding: 12px 16px;
    margin: 18px 0 0;
    font-weight: 800;
    color: #7a4400;
    font-size: 0.88rem;
    text-align: left;
  }
  .error-box.show {
    display: block;
    animation: shake 0.35s ease;
  }

  @keyframes shake {
    0%,100% { transform: translateX(0); }
    20%     { transform: translateX(-9px); }
    40%     { transform: translateX(9px); }
    60%     { transform: translateX(-5px); }
    80%     { transform: translateX(5px); }
  }

  .screen { display: none; }
  .screen.active { display: block; animation: popIn 0.3s ease both; }
  @keyframes popIn {
    from { opacity:0; transform: scale(0.92); }
    to   { opacity:1; transform: scale(1); }
  }

  .apology-text {
    font-size: 1rem;
    line-height: 1.8;
    color: #333;
    font-weight: 700;
    text-align: left;
    background: #f9f9f9;
    border-radius: 12px;
    padding: 18px 20px;
    margin: 16px 0 24px;
    border: 2px dashed #ccc;
  }

  .confetti-piece {
    position: fixed;
    pointer-events: none;
    opacity: 0;
    animation: fall 3s ease forwards;
  }
  @keyframes fall {
    0%   { opacity:1; transform: translateY(-10px) rotate(0deg); }
    100% { opacity:0; transform: translateY(100vh) rotate(800deg); }
  }

  .counter-badge {
    display: inline-block;
    background: #ff5c5c;
    color: white;
    border-radius: 20px;
    padding: 1px 8px;
    font-size: 0.75rem;
    margin-left: 5px;
  }

  .progress {
    height: 6px;
    background: #eee;
    border-radius: 99px;
    margin-bottom: 28px;
    overflow: hidden;
    border: 1.5px solid #ddd;
  }
  .progress-fill {
    height: 100%;
    background: #ffd93d;
    border-radius: 99px;
    transition: width 0.4s ease;
  }
</style>
</head>
<body>

<div class="card">
  <div class="progress"><div class="progress-fill" id="prog" style="width:0%"></div></div>

  <!-- SCREEN 1 -->
  <div class="screen active" id="s1">
    <span class="emoji-big">😬</span>
    <h1>are you mad at me?</h1>
    <p class="subtext">think very carefully 👀</p>
    <div class="btn-row">
      <button class="btn btn-yes" onclick="clickYes()">yes 😤</button>
      <button class="btn btn-no" id="btn-no" onclick="clickNo()">no 🙂</button>
    </div>
    <div class="error-box" id="err1"></div>
  </div>

  <!-- SCREEN 2: clicked yes -->
  <div class="screen" id="s-yes">
    <span class="emoji-big">💀</span>
    <h1>ok. valid. 😶</h1>
    <p class="subtext">okay, i respect it. but please dont be mad at me. <br>can you at least hear me out for 10 seconds??</p>
    <div class="btn-row">
      <button class="btn btn-ok" onclick="goApology()">fine. 10 seconds. go. 🙄</button>
    </div>
  </div>

  <!-- SCREEN 3: apology -->
  <div class="screen" id="s-apology">
    <span class="emoji-big">😶‍🌫️</span>
    <h1>okay so. 👉👈</h1>
    <div class="apology-text">
      I know what I said wasn't cool 😬. I'm genuinely sorry 😔. It wasn't a nice thing to say or wish for anyone — at all 🙅. Please don't be mad 😭, I didn't mean it in a bad way I promise 🤞.
    </div>
    <p class="subtext">so... are we good or nah 👀</p>
    <div class="btn-row">
      <button class="btn btn-yes" id="btn-notyet" onclick="notYet(this)">not yet 😒</button>
      <button class="btn btn-forgive" onclick="allGood()">fine we're good 🙄</button>
    </div>
    <div class="error-box" id="err2"></div>
  </div>

  <!-- SCREEN 4: resolved -->
  <div class="screen" id="s-end">
    <span class="emoji-big" style="animation:none; font-size:80px">🎉</span>
    <h1>SHE FORGAVE ME!!! 🥳</h1>
    <p class="subtext" style="font-size:1rem; color:#444; margin-bottom:0">
      okay cool. we're good. back to normal 😎<br>
      won't say shit like this again 😭🙏
    </p>
  </div>
</div>

<script>
  let noCount = 0;
  let notYetCount = 0;

  const noErrors = [
    '⚠️ ERROR 404: "No" not found. Please try "No" again.',
    '🚨 INVALID INPUT. The system only accepts "No". Retry.',
    '🤨 bro. BRO. click the yellow button.',
    '🛑 that button does not work. try the OTHER button that also says no.',
    '🤡 ur literally clicking the wrong thing on purpose at this point',
    '😭 i am BEGGING you. the YELLOW one.',
    '💀 okay i give up. click whatever u want. (please click no)',
    '🙃 fine. stay mad forever then. jk jk jk. CLICK NO.',
  ];

  const notYetErrors = [
    '😐 ERROR: forgiveness not submitted. please resubmit.',
    '🥲 ok that\'s fair. still not good? really??',
    '😮‍💨 alright alright alright. STILL not good??',
    '💀 i\'m going to pass away. just click the blue one.',
  ];

  const noLabels = [
    'no 🙂', 'no!! 😅', 'NO 😐', '...no 🫤',
    'no pls 😶', 'just no 😑', 'NO 😤', '...no. 🫠'
  ];

  function clickYes() {
    go('s-yes'); prog(33);
  }

  function clickNo() {
    noCount++;
    const err = document.getElementById('err1');
    err.innerHTML = noErrors[Math.min(noCount-1, noErrors.length-1)]
      + (noCount > 2 ? ` <span class="counter-badge">attempt #${noCount}</span>` : '');
    err.classList.remove('show');
    void err.offsetWidth;
    err.classList.add('show');
    const btn = document.getElementById('btn-no');
    btn.textContent = noLabels[Math.min(noCount, noLabels.length-1)];
  }

  function goApology() { go('s-apology'); prog(66); }

  function notYet(btn) {
    notYetCount++;
    const err = document.getElementById('err2');
    err.innerHTML = notYetErrors[Math.min(notYetCount-1, notYetErrors.length-1)];
    err.classList.remove('show');
    void err.offsetWidth;
    err.classList.add('show');
    btn.style.transform = `scale(${Math.max(0.55, 1 - notYetCount*0.12)})`;
    btn.style.opacity = Math.max(0.25, 1 - notYetCount*0.18);
  }

  function allGood() {
    go('s-end'); prog(100);
    confetti();
  }

  function go(id) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById(id).classList.add('active');
  }

  function prog(pct) {
    document.getElementById('prog').style.width = pct + '%';
    document.getElementById('prog').style.background = pct === 100 ? '#4ecb71' : '#ffd93d';
  }

  function confetti() {
    const shapes = ['🎉','🎊','✨','🥳','😎','🙌','🎈'];
    for (let i = 0; i < 40; i++) {
      const el = document.createElement('div');
      el.className = 'confetti-piece';
      el.textContent = shapes[Math.floor(Math.random()*shapes.length)];
      el.style.fontSize = (16 + Math.random()*20) + 'px';
      el.style.left = (Math.random()*100) + 'vw';
      el.style.top = '-30px';
      el.style.animationDelay = (Math.random()*1.8) + 's';
      el.style.animationDuration = (2 + Math.random()*2) + 's';
      document.body.appendChild(el);
      setTimeout(() => el.remove(), 5000);
    }
  }
</script>
</body>
</html>
